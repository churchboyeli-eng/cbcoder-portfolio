# ─────────────────────────────────────────────────────────────
# CBCODER Rental Booking — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Your business email that RECEIVES all booking notifications
SMTP_TO_EMAIL=your@email.com

# Gmail SMTP credentials (use an App Password, not your main password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here

# Site URL (used in email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
